# Backend API base URL (required in production).
# In development, Vite's dev server proxies /api and /socket.io to the backend,
# so this can be left empty.
VITE_API_BASE_URL=https://stand-alone-it-server.onrender.com

# Socket.IO server URL (optional — falls back to VITE_API_BASE_URL if not set)
VITE_SOCKET_URL=https://stand-alone-it-server.onrender.com
